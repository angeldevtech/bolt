{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Bolt",
  "version": "0.1.0",
  "identifier": "Bolt",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun x vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Bolt",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../binaries/yt-dlp.exe": "tools/yt-dlp.exe",
      "../binaries/ffmpeg.exe": "tools/ffmpeg.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
