{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "process:default",
    "store:default",
    "dialog:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-read-text"
  ]
}
